{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "-webkit-text-size-adjust",
          "user-select"
        ]
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_chr <= 148",
    "not and_ff <= 150",
    "not chrome <= 148",
    "not edge <= 148",
    "not firefox <= 150",
    "not ios_saf <= 26.4",
    "not opera <= 131",
    "not safari <= 26.4",
    "not samsung <= 29"
  ]
}